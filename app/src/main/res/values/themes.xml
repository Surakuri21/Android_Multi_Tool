<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Caerlangs_calculator" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="Theme.Caerlangs_calculator" parent="Base.Theme.Caerlangs_calculator" />

    <!-- ========================================= -->
    <!-- NEW CALCULATOR STYLES (DASHBOARD MATCHED) -->
    <!-- ========================================= -->

    <!-- Base styling for all buttons (Handles the Samsung rounded look and grid sizing) -->
    <style name="CalcButton" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">6dp</item>
        <item name="cornerRadius">32dp</item> <!-- Rounded Samsung feel -->
        <item name="android:textSize">24sp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <!-- Dark grey for numbers (0-9, .) -->
    <style name="CalcButton.Number" parent="CalcButton">
        <item name="backgroundTint">#2A2A2A</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>

    <!-- Dashboard Blue for operators (+, -, x, /, =) -->
    <style name="CalcButton.Primary" parent="CalcButton">
        <item name="backgroundTint">#4DABF7</item>
        <item name="android:textColor">#121212</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Light grey with blue text for top row (C, +/-, %) -->
    <style name="CalcButton.Secondary" parent="CalcButton">
        <item name="backgroundTint">#1E1E1E</item>
        <item name="android:textColor">#4DABF7</item>
    </style>

</resources>