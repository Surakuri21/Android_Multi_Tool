<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Header / Back Navigation -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <ImageButton
            android:id="@+id/btnBackToDashboard"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            app:tint="#4DABF7"
            android:contentDescription="Go Back"
            android:layout_marginEnd="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Calculator"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Display Screen -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="bottom|end"
        android:paddingBottom="24dp"
        android:paddingEnd="8dp">


        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="56sp"
            android:textStyle="bold"
            android:gravity="end"
            android:maxLines="1"
            app:autoSizeTextType="uniform"
            app:autoSizeMinTextSize="24sp"
            app:autoSizeMaxTextSize="56sp"/>

        <TextView
            android:id="@+id/tvEquation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#A0A0A0"
            android:textSize="24sp"
            android:gravity="end"
            android:layout_marginBottom="8dp"/>


        <ImageButton
            android:id="@+id/btnBackspace"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="1dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_backspace"
            app:tint="#4DABF7"
            android:contentDescription="Backspace" />

    </LinearLayout>

    <!-- Divider Line -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#333333"
        android:layout_marginBottom="16dp"/>

    <!-- Keypad Grid (Samsung Inspired Structure) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2.5"
        android:orientation="vertical">

        <!-- Row 1: C, +/-, %, ÷ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnC" style="@style/CalcButton.Secondary" android:text="C" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPlusMinus" style="@style/CalcButton.Secondary" android:text="+/-" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPercent" style="@style/CalcButton.Secondary" android:text="%" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDivide" style="@style/CalcButton.Primary" android:text="÷" />
        </LinearLayout>

        <!-- Row 2: 7, 8, 9, × -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn7" style="@style/CalcButton.Number" android:text="7" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn8" style="@style/CalcButton.Number" android:text="8" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn9" style="@style/CalcButton.Number" android:text="9" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMultiply" style="@style/CalcButton.Primary" android:text="×" />
        </LinearLayout>

        <!-- Row 3: 4, 5, 6, - -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn4" style="@style/CalcButton.Number" android:text="4" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn5" style="@style/CalcButton.Number" android:text="5" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn6" style="@style/CalcButton.Number" android:text="6" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMinus" style="@style/CalcButton.Primary" android:text="−" />
        </LinearLayout>

        <!-- Row 4: 1, 2, 3, + -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn1" style="@style/CalcButton.Number" android:text="1" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn2" style="@style/CalcButton.Number" android:text="2" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn3" style="@style/CalcButton.Number" android:text="3" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPlus" style="@style/CalcButton.Primary" android:text="+" />
        </LinearLayout>

        <!-- Row 5: 0, ., = -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn0"
                style="@style/CalcButton.Number"
                android:layout_weight="2"
                android:text="0" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDot" style="@style/CalcButton.Number" android:text="." />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEquals" style="@style/CalcButton.Primary" android:text="=" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>